# Copy this file to .env.local and fill in real values. .env.local is
# gitignored, so your actual values never get committed.

# Optional: your own Solana RPC endpoint (Helius, QuickNode, Alchemy, etc.).
# Falls back to a public endpoint if unset.
VITE_CLUSTER_URL=

# Required for the "leave an offering" USDC tip button to work: the Solana
# wallet address that receives tips.
VITE_TIP_DESTINATION_WALLET=
